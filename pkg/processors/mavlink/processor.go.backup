	lat, ok := data["latitude"].(float64)
	if !ok {
		return fmt.Errorf("missing or invalid latitude")
	}
	
	lon, ok := data["longitude"].(float64)
	if !ok {
		return fmt.Errorf("missing or invalid longitude")
	}
	
	// Create and publish position message
	position := payloads.NewPositionPayload(uint8(systemID), time.Now(), lat, lon)
	
	// Wrap in Message
	msg := messages.NewBaseMessage(
		position.Schema(),
		position,
		"robotics-processor",
	)
	
	// Marshal the MESSAGE
	msgBytes, err := json.Marshal(msg)
	if err != nil {
		return fmt.Errorf("failed to marshal position message: %w", err)
	}
	
	rp.mu.RLock()
	subject := fmt.Sprintf("semantic.%s.position", rp.config.OutputPrefix)
	rp.mu.RUnlock()
	return nc.Publish(subject, msgBytes)
}

